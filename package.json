{
	"name": "cmdi",
	"private": true,
	"license": "MIT",
	"author": "raine",
	"type": "module",
	"scripts": {
		"commit": "commit",
		"lint": "eslint --cache",
		"lint:ci": "eslint --cache --cache-strategy content",
		"lint:fix": "eslint --cache --fix",
		"lint:inspect": "pnpx @eslint/config-inspector",
		"packages:build": "pnpm --filter \"./packages/*\" build",
		"packages:watch": "pnpm --filter \"./packages/*\" watch",
		"prepare": "husky"
	},
	"dependencies": {
		"@commitlint/prompt-cli": "catalog:script"
	},
	"devDependencies": {
		"@commitlint/cli": "catalog:script",
		"@commitlint/config-angular": "catalog:script",
		"@commitlint/types": "catalog:types",
		"@eslint/config-inspector": "catalog:lint",
		"@isentinel/eslint-config": "catalog:lint",
		"eslint": "catalog:lint",
		"eslint-plugin-pnpm": "catalog:lint",
		"eslint-plugin-react-hooks": "catalog:lint",
		"eslint-plugin-react-naming-convention": "catalog:lint",
		"eslint-plugin-react-x": "catalog:lint",
		"husky": "catalog:script",
		"jiti": "catalog:script"
	},
	"packageManager": "pnpm@10.30.1"
}
